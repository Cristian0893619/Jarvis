# =========================================================================
# Proyecto J.A.R.V.I.S. (IntelliJ + Java + Python)
# =========================================================================

# --- Compilación y Salidas de Java / Kotlin (JVM) ---
*.class
*.log
*.jar
*.war
*.ear
/out/
/bin/

# --- Gestor de Dependencias: Gradle ---
.gradle/
/build/
/*-boot.jar

# Conservar el wrapper de Gradle para que otros puedan compilar el proyecto sin instalar Gradle
!gradle/wrapper/gradle-wrapper.jar
!gradle/wrapper/gradle-wrapper.properties

# --- Archivos de Configuración de IntelliJ IDEA ---
.idea/
*.iml
*.iws
*.ipr
out/

# Excepciones de IntelliJ: Sí queremos subir la configuración de estilos de código si existiera
!.idea/codeStyles/

# --- Entornos Virtuales y Caché de Python (Para componentes de IA) ---
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.htmlcov/
flake8.txt
/venv/
/env/
/.venv/
/ENV/

# --- Archivos del Sistema Operativo ---
.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini

# --- CRÍTICO: Secretos, Credenciales y Variables de Entorno ---
# Jamás subir tokens de APIs (Gemini, OpenAI, ElevenLabs, Picovoice, etc.)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# Archivos de propiedades locales de la JVM
secrets.properties
local.properties
credentials.json

# Llaves criptográficas y certificados de seguridad
*.pem
*.key
*.pub
*.p12
